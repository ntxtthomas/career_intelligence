<% content_for :title, "Dashboard" %>

<h1 style="padding-top: 1.5rem;">Career Intelligence Dashboard</h1>

<!-- Row 1: KPI Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="card card-submitted">
    <div class="card-header justify-center text-center">
      <h3>Total Applications Submitted</h3>
    </div>
    <div class="card-body">
      <div class="card-number"><%= @total_resumes %></div>
      <p class="card-subtitle">Total applications sent</p>
    </div>
  </div>

  <div class="card card-open-applications">
    <div class="card-header justify-center text-center">
      <h3>Total Open Applications</h3>
    </div>
    <div class="card-body">
      <div class="card-number"><%= @total_open_applications %></div>
      <p class="card-subtitle">Current Applications in Flight</p>
    </div>
  </div>

  <div class="card card-assessed">
    <div class="card-header justify-center text-center">
      <h3>Assessed Opportunities</h3>
    </div>
    <div class="card-body">
      <div class="card-number"><%= @total_assessed %></div>
      <p class="card-subtitle">Total opportunities tracked</p>
    </div>
  </div>
</div>

<!-- Row 2: Applications by Week -->
<div class="card mb-6">
  <div class="card-header justify-between">
    <h3>Applications by Week</h3>
    <div class="card-icon">📅</div>
  </div>
  <div class="card-body">
    <div class="flex flex-wrap gap-3">
      <% @weekly_data.each do |week| %>
        <% card_class = week[:meets_requirement] ? "card card-week card-week-success clickable-week-card flex-1 min-w-[140px]" : "card card-week card-week-warning clickable-week-card flex-1 min-w-[140px]" %>
        <%= link_to opportunities_path(start_date: week[:start_date], end_date: week[:end_date]), class: card_class, style: "text-decoration: none; color: inherit;" do %>
          <div class="card-header justify-center text-center">
            <h3><%= week[:label] %></h3>
          </div>
          <div class="card-body">
            <div class="card-number"><%= week[:count] %></div>
            <p class="card-subtitle">applications</p>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<!-- Row 3: Tech Skills + Source Distribution -->
<div class="grid grid-cols-1 lg:grid-cols-5 gap-4 mb-6">
  <% if @focus_insights.any? %>
    <div class="card lg:col-span-3">
      <div class="card-header justify-between">
        <h3>🎯 Top 4 Tech Skills to Focus On</h3>
        <div class="card-icon">📚</div>
      </div>
      <div class="card-body">
        <div class="py-2.5">
          <% @focus_insights.each_with_index do |insight, index| %>
            <div class="mb-5 p-4 rounded <%= index == 0 ? 'bg-purple-500/5 border-l-4 border-purple-600' : 'bg-[var(--bg-primary)] border-l-4 border-gray-300' %>">
              <div class="flex flex-wrap justify-between items-center mb-2 gap-2">
                <div>
                  <span class="font-bold text-base text-[var(--text-primary)]"><%= index + 1 %>. <%= insight[:name] %></span>
                  <% if index == 0 %>
                    <span class="bg-purple-600 text-white px-2 py-0.5 rounded text-[11px] ml-2 font-bold">TOP PRIORITY</span>
                  <% end %>
                </div>
                <% if insight[:percentage].present? %>
                  <span class="text-xl font-bold text-purple-600"><%= insight[:percentage] %>%</span>
                <% end %>
              </div>
              <div class="text-sm text-[var(--text-secondary)] mb-1">
                <%= insight[:insight] %>
              </div>
              <% if insight[:count].present? %>
                <div class="text-xs text-[var(--text-muted)]">
                  Appears in <strong><%= insight[:count] %></strong> of your tracked opportunities
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @source_data.any? %>
    <div class="card lg:col-span-2">
      <div class="card-header justify-between">
        <h3>Source Distribution</h3>
        <div class="card-icon">🔍</div>
      </div>
      <div class="card-body">
        <div class="tech-stack-chart">
          <% max_count_source = @source_data.values.max %>
          <% @source_data.first(6).each do |source, count| %>
            <div class="chart-bar-container mb-2">
              <div class="chart-label min-w-[100px] text-[13px]"><%= source&.humanize %></div>
              <div class="chart-bar-wrapper">
                <div class="chart-bar" style="width: <%= (count.to_f / max_count_source * 100).round(1) %>%;">
                  <span class="chart-count"><%= count %></span>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Lower Section: Individual Role Focus Widgets -->
<% if @all_role_insights.any? %>
  <%
    role_colors = {
      "software_engineer" => "#6c757d",
      "sales_engineer" => "#28a745",
      "solutions_engineer" => "#17a2b8",
      "product_manager" => "#6f42c1",
      "support_engineer" => "#fd7e14",
      "success_engineer" => "#20c997",
      "other" => "#343a40"
    }
  %>
  
  <div class="mt-12">
    <h1 class="mb-6 text-[var(--text-primary)]">Focus Areas by Role Type</h1>
    <div class="role-focus-grid">
      <% @all_role_insights.each do |role_type, data| %>
        <% next if role_type == @primary_role %>
        <% badge_color = role_colors[role_type] || "#6c757d" %>
        
        <div class="card" style="border-left-color: <%= badge_color %>;">
          <div class="card-header justify-between">
            <div>
              <h3 class="mb-2"><%= data[:label] %></h3>
              <p class="m-0 text-xs text-[var(--text-muted)]"><%= data[:count] %> <%= data[:count] == 1 ? 'opportunity' : 'opportunities' %></p>
            </div>
            <div class="card-icon">💼</div>
          </div>
          <div class="card-body text-left">
            <div class="py-1">
              <% data[:insights].each_with_index do |insight, index| %>
                <div class="mb-4 pb-4 <%= index < data[:insights].length - 1 ? 'border-b border-[var(--border-color)]' : '' %>">
                  <div class="font-semibold text-sm text-[var(--text-primary)] mb-1">
                    <%= index + 1 %>. <%= insight[:name] %>
                  </div>
                  <div class="text-xs text-[var(--text-secondary)] leading-relaxed">
                    <%= insight[:insight] %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
