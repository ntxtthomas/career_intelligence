<%= form_with(model: resource_guide_question) do |form| %>
  <% if resource_guide_question.errors.any? %>
    <div class="alert">
      <h2><%= pluralize(resource_guide_question.errors.count, "error") %> prohibited this question from being saved:</h2>
      <ul>
        <% resource_guide_question.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form.hidden_field :guide_type %>

  <div class="form-group">
    <%= form.label :section_title, "Section", class: "form-label" %>
    <%= form.text_field :section_title, class: "form-input", placeholder: "e.g., Debugging & Reliability" %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :question, class: "form-label" %>
      <%= form.rich_text_area :question, class: "form-textarea" %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :meaning, "What it means", class: "form-label" %>
      <%= form.rich_text_area :meaning, class: "form-textarea" %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :response_approach, "Strong response approach", class: "form-label" %>
      <%= form.rich_text_area :response_approach, class: "form-textarea" %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :example_response, "Good response pattern", class: "form-label" %>
      <%= form.rich_text_area :example_response, class: "form-textarea" %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :pitfall, "Pitfall to avoid", class: "form-label" %>
      <%= form.rich_text_area :pitfall, class: "form-textarea" %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :why_this_is_strong, "Why this is strong", class: "form-label" %>
      <%= form.rich_text_area :why_this_is_strong, class: "form-textarea" %>
    <small class="form-hint">Useful for interviewer-question style entries.</small>
  </div>

  <div class="form-actions">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
