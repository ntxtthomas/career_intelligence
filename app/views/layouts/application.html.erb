<!DOCTYPE html>
<html>

<head>
  <title><%= content_for(:title) || "Career Intelligence" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
  <meta name="theme-color" content="#1a1a2e">

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon-512a.png">


  <%# Includes all stylesheet files in app/assets/stylesheets %>
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body>
  <div id="pwa-splash" style="display:none; position:fixed; inset:0; z-index:9999; background:#1a1a2e; align-items:center; justify-content:center; flex-direction:column; transition:opacity 0.5s ease;">
    <img src="/splash.png" style="width:100%; height:100%; object-fit:cover;">
  </div>
  <script>
    (function() {
      var isStandalone = window.navigator.standalone === true ||
                         window.matchMedia('(display-mode: standalone)').matches;
      if (isStandalone && !sessionStorage.getItem('splashShown')) {
        sessionStorage.setItem('splashShown', '1');
        var splash = document.getElementById('pwa-splash');
        splash.style.display = 'flex';
        splash.style.opacity = '1';
        setTimeout(function() {
          splash.style.opacity = '0';
          setTimeout(function() { splash.style.display = 'none'; }, 500);
        }, 1500);
      }
    })();
  </script>
  <% unless controller_name == "sessions" && action_name == "new" %>
  <nav class="bg-[var(--bg-secondary)] border-b border-[var(--border-color)] sticky top-0 z-50" data-controller="nav">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between h-14">
        <!-- Logo / Brand -->
        <%= link_to dashboard_path, class: "shrink-0 flex items-center" do %>
          <%= image_tag "/icon-512.png", alt: "Career Intelligence", style: "height: 36px; width: auto; display: block; transition: opacity 0.15s ease, transform 0.15s ease;", onmouseover: "this.style.opacity='0.8'; this.style.transform='scale(1.05)'", onmouseout: "this.style.opacity='1'; this.style.transform='scale(1)'", onmousedown: "this.style.transform='scale(0.95)'", onmouseup: "this.style.transform='scale(1.05)'" %>
        <% end %>

        <!-- Desktop links -->
        <div class="hidden md:flex items-center gap-1">
          <%= link_to "Companies", companies_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:text-blue-700 dark:hover:text-blue-300 px-3 py-2 rounded-md text-sm" %>
          <%= link_to "Contacts", contacts_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:text-blue-700 dark:hover:text-blue-300 px-3 py-2 rounded-md text-sm" %>
          <%= link_to "Opportunities", opportunities_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:text-blue-700 dark:hover:text-blue-300 px-3 py-2 rounded-md text-sm" %>
          <%= link_to "Interviews", interview_sessions_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:text-blue-700 dark:hover:text-blue-300 px-3 py-2 rounded-md text-sm" %>
          <%= link_to "Resources", resource_sheets_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:text-blue-700 dark:hover:text-blue-300 px-3 py-2 rounded-md text-sm" %>
          <%= link_to "STAR", star_stories_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:text-blue-700 dark:hover:text-blue-300 px-3 py-2 rounded-md text-sm" %>
          <% if user_signed_in? %>
            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-red-500 dark:text-red-400 no-underline hover:text-red-700 dark:hover:text-red-300 px-3 py-2 rounded-md text-sm ml-2" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:text-blue-700 dark:hover:text-blue-300 px-3 py-2 rounded-md text-sm ml-2" %>
          <% end %>
        </div>

        <!-- Hamburger button (mobile) -->
        <button data-action="nav#toggle" class="md:hidden p-2 rounded-md text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)]" aria-label="Toggle menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div class="hidden md:hidden pb-3" data-nav-target="menu">
        <div class="flex flex-col gap-1">
          <%= link_to "Companies", companies_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:bg-[var(--bg-tertiary)] px-3 py-2 rounded-md text-sm", data: { action: "nav#close" } %>
          <%= link_to "Contacts", contacts_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:bg-[var(--bg-tertiary)] px-3 py-2 rounded-md text-sm", data: { action: "nav#close" } %>
          <%= link_to "Opportunities", opportunities_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:bg-[var(--bg-tertiary)] px-3 py-2 rounded-md text-sm", data: { action: "nav#close" } %>
          <%= link_to "Interviews", interview_sessions_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:bg-[var(--bg-tertiary)] px-3 py-2 rounded-md text-sm", data: { action: "nav#close" } %>
          <%= link_to "Resources", resource_sheets_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:bg-[var(--bg-tertiary)] px-3 py-2 rounded-md text-sm", data: { action: "nav#close" } %>
          <%= link_to "STAR", star_stories_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:bg-[var(--bg-tertiary)] px-3 py-2 rounded-md text-sm", data: { action: "nav#close" } %>
          <hr class="border-[var(--border-color)] my-1">
          <% if user_signed_in? %>
            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete, action: "nav#close" }, class: "text-red-500 dark:text-red-400 no-underline hover:bg-[var(--bg-tertiary)] px-3 py-2 rounded-md text-sm" %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "text-blue-500 dark:text-blue-400 no-underline hover:bg-[var(--bg-tertiary)] px-3 py-2 rounded-md text-sm", data: { action: "nav#close" } %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>
  <% end %>

  <div class="page-container">
    <% if notice.present? %>
      <p class="notice"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="alert"><%= alert %></p>
    <% end %>
    <%= yield %>
  </div>
</body>

</html>
