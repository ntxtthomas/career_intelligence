<div id="<%= dom_id contact %>">
  <h1 style="padding-top: 1.5rem;"><%= contact.name %></h1>

  <div class="contact-details">
    <% if contact.title.present? %>
    <p>
      <strong>Title:</strong>
      <%= contact.title %>
    </p>
    <% end %>

    <% if contact.email.present? %>
    <p>
      <strong>Email:</strong>
      <%= link_to contact.email, "mailto:#{contact.email}" %>
    </p>
    <% end %>

    <% if contact.phone.present? %>
    <p>
      <strong>Phone:</strong>
      <%= link_to contact.phone, "tel:#{contact.phone}" %>
    </p>
    <% end %>

    <% if contact.linkedin.present? %>
    <p>
      <strong>LinkedIn:</strong>
      <%= link_to contact.linkedin, contact.linkedin, target: "_blank", rel: "noopener noreferrer" %>
    </p>
    <% end %>

    <% if contact.company %>
    <p>
      <strong>Company:</strong>
      <%= link_to contact.company.name, contact.company %>
    </p>
    <% end %>

    <% if contact.about.present? %>
    <p>
      <strong>About:</strong>
    </p>
    <div style="margin-top: 8px; margin-bottom: 15px; padding: 10px; background-color: var(--bg-secondary, #f8f9fa); border-radius: 4px; word-wrap: break-word;">
      <div class="trix-content">
        <%= contact.about %>
      </div>
    </div>
    <% end %>

    <% if contact.notes.present? %>
    <p>
      <strong>Notes:</strong>
    </p>
    <div style="margin-top: 8px; margin-bottom: 15px; padding: 10px; background-color: var(--bg-secondary, #f8f9fa); border-radius: 4px; word-wrap: break-word;">
      <div class="trix-content">
        <%= contact.notes %>
      </div>
    </div>
    <% end %>
  </div>
</div>
